{
  "name": "djmond",
  "version": "1.1.0",
  "description": "DiamondJdev's opinionated CLI wrapper",
  "type": "module",
  "bin": {
    "dj": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.4.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "developer-tools",
    "npm",
    "git"
  ],
  "author": "DiamondJdev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiamondJdev/djCLI.git"
  },
  "homepage": "https://github.com/DiamondJdev/djCLI#readme",
  "bugs": {
    "url": "https://github.com/DiamondJdev/djCLI/issues"
  }
}
